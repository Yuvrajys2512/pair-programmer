# Get your free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Default model — Groq's strongest general model on the free tier.
# Alternatives: qwen-2.5-coder-32b (better at code, weaker at personality),
#               deepseek-r1-distill-llama-70b (reasoning, slower output)
GROQ_MODEL=llama-3.3-70b-versatile
